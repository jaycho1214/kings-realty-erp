{
  "name": "kingsrealty",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @kingsrealty/db migrate",
    "db:migrate:down": "pnpm --filter @kingsrealty/db migrate:down",
    "db:generate": "pnpm --filter @kingsrealty/db generate",
    "db:seed": "pnpm --filter @kingsrealty/db seed"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "turbo": "^2.10.1"
  }
}
