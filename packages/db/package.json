{
  "name": "@kingsrealty/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "migrate": "tsx src/migrate.ts",
    "migrate:down": "tsx src/migrate.ts down",
    "generate": "kysely-codegen --dialect postgres --env-file .env --out-file src/types.ts",
    "db:up": "tsx src/migrate.ts && kysely-codegen --dialect postgres --env-file .env --out-file src/types.ts",
    "seed": "tsx src/seed.ts",
    "migrate:crm": "tsx src/migrate-crm.ts"
  },
  "dependencies": {
    "@vercel/functions": "^2.0.0",
    "kysely": "^0.28.11",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@better-auth/kysely-adapter": "^1.5.4",
    "@types/pg": "^8.11.6",
    "better-auth": "^1.5.4",
    "dotenv": "^17.3.1",
    "kysely-codegen": "^0.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
